{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TelemetryForge",
  "version": "0.1.0",
  "identifier": "io.github.riccione83.telemetryforge",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TelemetryForge",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
